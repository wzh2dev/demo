{
  "mcpServers": {
    "codegraph": {
      "command": "npx",
      "args": [
        "@colbymchenry/codegraph",
        "serve",
        "--mcp"
      ]
    },
    "drawio": {
      "command": "npx",
      "args": [
        "@next-ai-drawio/mcp-server@latest"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--browser=chrome"
      ]
    },
    "postgres": {
      "command": "npx",
      "args": [
        "@modelcontextprotocol/server-postgres",
        "postgresql://postgres:postgres@xueyingying.com/demo"
      ]
    }
  }
}