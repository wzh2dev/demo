# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.java]
indent_style = space
indent_size = 4

[*.scala]
indent_style = space
indent_size = 2

[*.py]
indent_style = space
indent_size = 4

[*.{js,jsx,ts,tsx,html,less,css}]
indent_style = space
indent_size = 2

[*.{json,yml}]
indent_style = space
indent_size = 2
insert_final_newline = true

[*.xml]
indent_style = space
indent_size = 2
